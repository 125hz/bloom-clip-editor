{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bloom Editor",
  "version": "2.5.0",
  "identifier": "com.125hz.bloomclipeditor",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "bloom editor",
        "width": 1600,
        "height": 900,
        "minWidth": 980,
        "minHeight": 620,
        "backgroundColor": "#000000",
        "dragDropEnabled": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/ffmpeg", "binaries/ffprobe"],
    "resources": {
      "vapoursynth/": "vapoursynth/",
      "rife-models/": "rife-models/",
      "rife_blur.vpy": "rife_blur.vpy",
      "RUNTIME_NOTICES.md": "RUNTIME_NOTICES.md"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
